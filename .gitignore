# .gitignore
writable/*
!writable/index.html
!writable/.htaccess
!writable/cache/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/uploads/.gitkeep
app/Config/Database.php
vendor/
.env
.env_production
.env.production
.env.local
.env.*.local
node_modules
_archived/
# Debug / temporary files
debug_audit.php
MARKETING_FIXES.json
# Credentials (NEVER COMMIT!)
.credentials/
*.credentials
production.txt
# Backups & SQL dumps (contains sensitive DB data)
backups/
*.sql
*.sql.gz
*.bak
# Private keys & certificates
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
