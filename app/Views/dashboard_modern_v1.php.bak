<script>
// Real-time clock
function updateDateTime() {
    const now = new Date();
    const options = { 
        weekday: 'long', 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    };
    document.getElementById('currentDateTime').textContent = now.toLocaleDateString('id-ID', options);
}
updateDateTime();
setInterval(updateDateTime, 60000);

// Counter animation for KPI numbers
document.querySelectorAll('.counter').forEach(counter => {
    const target = parseFloat(counter.getAttribute('data-target'));
    const duration = 2000;
    const increment = target / (duration / 16);
    let current = 0;
    
    const updateCounter = () => {
        current += increment;
        if (current < target) {
            counter.textContent = Math.floor(current * 10) / 10;
            requestAnimationFrame(updateCounter);
        } else {
            counter.textContent = target;
        }
    };
    
    updateCounter();
});

// Chart.js Global Configuration
Chart.defaults.font.family = 'Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
Chart.defaults.font.size = 13;
Chart.defaults.color = '#6c757d';

const chartColors = {
    primary: '#0061f2',
    success: '#00ac69',
    warning: '#ffc107',
    danger: '#dc3545',
    info: '#17a2b8',
    purple: '#6f42c1',
    orange: '#fd7e14',
    teal: '#20c997'
};

// Chart 1: Fleet Performance (Donut Chart)
const fleetCtx = document.getElementById('fleetChart').getContext('2d');
new Chart(fleetCtx, {
    type: 'doughnut',
    data: {
        labels: ['Rented', 'Available', 'Maintenance', 'Out of Service'],
        datasets: [{
            data: <?= json_encode($charts['fleet']['data']) ?>,
            backgroundColor: [
                chartColors.success,
                chartColors.primary,
                chartColors.warning,
                chartColors.danger
            ],
            borderWidth: 0
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'bottom',
                labels: {
                    padding: 15,
                    usePointStyle: true
                }
            },
            tooltip: {
                backgroundColor: 'rgba(0,0,0,0.9)',
                padding: 12,
                cornerRadius: 8
            }
        },
        cutout: '70%'
    }
});

// Chart 2: Service Performance (Line Chart)
const serviceCtx = document.getElementById('serviceChart').getContext('2d');
new Chart(serviceCtx, {
    type: 'line',
    data: {
        labels: <?= json_encode($charts['service']['labels']) ?>,
        datasets: [{
            label: 'WO Completion Rate (%)',
            data: <?= json_encode($charts['service']['wo_completion']) ?>,
            borderColor: chartColors.primary,
            backgroundColor: 'rgba(0, 97, 242, 0.1)',
            fill: true,
            tension: 0.4
        }, {
            label: 'Avg Response Time (hours)',
            data: <?= json_encode($charts['service']['response_time']) ?>,
            borderColor: chartColors.warning,
            backgroundColor: 'rgba(255, 193, 7, 0.1)',
            fill: true,
            tension: 0.4
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'top',
                labels: {
                    usePointStyle: true
                }
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                grid: {
                    color: '#f1f3f5'
                }
            }
        }
    }
});

// Chart 3: Delivery Performance (Bar + Line)
const deliveryCtx = document.getElementById('deliveryChart').getContext('2d');
new Chart(deliveryCtx, {
    type: 'bar',
    data: {
        labels: <?= json_encode($charts['delivery']['labels']) ?>,
        datasets: [{
            type: 'bar',
            label: 'Total Deliveries',
            data: <?= json_encode($charts['delivery']['total']) ?>,
            backgroundColor: chartColors.primary,
            order: 2
        }, {
            type: 'line',
            label: 'On-Time Rate (%)',
            data: <?= json_encode($charts['delivery']['on_time_rate']) ?>,
            borderColor: chartColors.success,
            backgroundColor: 'rgba(0, 172, 105, 0.1)',
            fill: true,
            tension: 0.4,
            order: 1
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'top',
                labels: {
                    usePointStyle: true
                }
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                grid: {
                    color: '#f1f3f5'
                }
            }
        }
    }
});

// Chart 4: Customer Satisfaction (Mixed Chart)
const customerCtx = document.getElementById('customerChart').getContext('2d');
new Chart(customerCtx, {
    type: 'line',
    data: {
        labels: <?= json_encode($charts['customer']['labels']) ?>,
        datasets: [{
            label: 'Active Customers',
            data: <?= json_encode($charts['customer']['active']) ?>,
            borderColor: chartColors.primary,
            backgroundColor: 'rgba(0, 97, 242, 0.1)',
            fill: true,
            tension: 0.4
        }, {
            label: 'Renewal Rate (%)',
            data: <?= json_encode($charts['customer']['renewal_rate']) ?>,
            borderColor: chartColors.success,
            backgroundColor: 'rgba(0, 172, 105, 0.1)',
            fill: true,
            tension: 0.4
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'top',
                labels: {
                    usePointStyle: true
                }
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                grid: {
                    color: '#f1f3f5'
                }
            }
        }
    }
});

// Chart 5: Asset Health (Stacked Bar)
const assetHealthCtx = document.getElementById('assetHealthChart').getContext('2d');
new Chart(assetHealthCtx, {
    type: 'bar',
    data: {
        labels: <?= json_encode($charts['asset_health']['labels']) ?>,
        datasets: [{
            label: 'Excellent',
            data: <?= json_encode($charts['asset_health']['excellent']) ?>,
            backgroundColor: chartColors.success
        }, {
            label: 'Good',
            data: <?= json_encode($charts['asset_health']['good']) ?>,
            backgroundColor: chartColors.primary
        }, {
            label: 'Fair',
            data: <?= json_encode($charts['asset_health']['fair']) ?>,
            backgroundColor: chartColors.warning
        }, {
            label: 'Needs Attention',
            data: <?= json_encode($charts['asset_health']['needs_attention']) ?>,
            backgroundColor: chartColors.danger
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'top',
                labels: {
                    usePointStyle: true
                }
            }
        },
        scales: {
            x: {
                stacked: true
            },
            y: {
                stacked: true,
                beginAtZero: true,
                grid: {
                    color: '#f1f3f5'
                }
            }
        }
    }
});

// Chart 6: Operational Efficiency (Radar)
const efficiencyCtx = document.getElementById('efficiencyChart').getContext('2d');
new Chart(efficiencyCtx, {
    type: 'radar',
    data: {
        labels: [
            'Fleet Utilization',
            'Service Response',
            'Delivery Accuracy',
            'PMPS Compliance',
            'Customer Satisfaction',
            'Permit Compliance'
        ],
        datasets: [{
            label: 'Current Performance',
            data: <?= json_encode($charts['efficiency']['current']) ?>,
            borderColor: chartColors.primary,
            backgroundColor: 'rgba(0, 97, 242, 0.2)',
            pointBackgroundColor: chartColors.primary,
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: chartColors.primary
        }, {
            label: 'Target',
            data: [85, 95, 98, 100, 90, 100],
            borderColor: chartColors.success,
            backgroundColor: 'rgba(0, 172, 105, 0.1)',
            pointBackgroundColor: chartColors.success,
            pointBorderColor: '#fff',
            borderDash: [5, 5]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'top',
                labels: {
                    usePointStyle: true
                }
            }
        },
        scales: {
            r: {
                beginAtZero: true,
                max: 100,
                ticks: {
                    stepSize: 20
                },
                grid: {
                    color: '#f1f3f5'
                }
            }
        }
    }
});

console.log('✅ OPTIMA Modern Dashboard loaded successfully');
</script>
<?= $this->endSection() ?>
