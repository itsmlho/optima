    {
        $id = (int)$id; if($id<=0) return $this->response->setJSON(['success'=>false,'message'=>'ID tidak valid','csrf_hash'=>csrf_hash()]);
        // Placeholder static rows; adapt to actual maintenance tables when ready.
        $history = [
