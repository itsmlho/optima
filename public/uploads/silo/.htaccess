# Security for SILO uploads directory
# Deny PHP execution
<Files "*.php">
    Order Deny,Allow
    Deny from all
</Files>

# Allow only PDF and image files
<FilesMatch "\.(pdf|jpg|jpeg|png)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Disable directory listing
Options -Indexes

# Set proper MIME types
<IfModule mod_mime.c>
    AddType application/pdf .pdf
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
</IfModule>

